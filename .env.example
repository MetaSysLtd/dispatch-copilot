# Postgres / Neon connection string
# Replace with your actual Neon connection string when ready
DATABASE_URL=postgres://user:password@host.neon.tech/dispatch_copilot?sslmode=require

# Session signing secret — generate a random string for each environment
SESSION_SECRET=change-me-to-a-long-random-string

# Server port (Express + WebSocket)
PORT=5000

# Operations timezone — DO NOT CHANGE. All scoring, cron, outreach uses this.
OPS_TZ=America/New_York

# Default org id (UUID) — shared by import-carriers and seed-users scripts
DEFAULT_ORG_ID=28d09f64-02a1-4d73-be3d-11fd84045a91

NODE_ENV=development
